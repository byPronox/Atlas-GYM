create table Ejercicio (idEjercicio bigint generated by default as identity (start with 1), activo boolean not null, grupoMuscular varchar(100), nombre varchar(100), tipo varchar(50), primary key (idEjercicio))
create table Rutina (idRutina bigint generated by default as identity (start with 1), descripcionGeneral varchar(255), nivelDificultad varchar(50), nombre varchar(100), objetivoPrincipal varchar(100), primary key (idRutina))
create table RutinaEjercicio (idRutinaEjercicio bigint generated by default as identity (start with 1), observaciones varchar(255), orden integer, repeticiones integer, series integer, ejercicio_idEjercicio bigint, rutina_idRutina bigint, primary key (idRutinaEjercicio))
alter table RutinaEjercicio add constraint FKsrl65rmm2ocb0tq1olik3ywh2 foreign key (ejercicio_idEjercicio) references Ejercicio
alter table RutinaEjercicio add constraint FK99hne0jnc7kwv90eod360f5t4 foreign key (rutina_idRutina) references Rutina
